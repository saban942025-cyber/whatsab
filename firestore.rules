rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // allow any signed in user to read and write to the main collections
    match /messages/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /drivers/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /warehouses/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /orders/{docId} {
      allow read, write: if request.auth != null;
    }

    match /test/connection {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
