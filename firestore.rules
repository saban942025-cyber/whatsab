rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Basic authentication check
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Validate message structure
    function isValidMessage(data) {
      return data.text is string 
        && data.senderId is string 
        && data.type in ['text', 'audio', 'system', 'order_card'];
    }

    // --- Core Logistics Collections ---

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(request.resource.data);
      allow update, delete: if false;
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    match /warehouses/{warehouseId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    // Seed/Diagnostic point
    match /test/connection {
      allow read: if isSignedIn();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
