rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---
    
    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp', 'type'])
        && data.text is string && data.text.size() <= 10000
        && data.senderId is string && data.senderId.size() <= 128
        && data.senderName is string && data.senderName.size() <= 200
        && data.timestamp == request.time
        && data.type in ['text', 'audio', 'system', 'order_card']
        // Optional fields check
        && (data.get('audioUrl', null) == null || data.audioUrl is string)
        && (data.get('orderData', null) == null || data.orderData is map)
        && (data.get('orderId', null) == null || data.orderId is string);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'status', 'extractedAt'])
        && data.customerName is string && data.customerName.size() <= 400
        && data.status in ['pending', 'approved', 'rejected', 'dispatched']
        && data.extractedAt is string;
    }

    function isValidDriver(data) {
      return data.keys().hasAll(['name', 'status'])
        && data.name is string && data.name.size() <= 200
        && data.status in ['active', 'on_route', 'maintenance', 'off']
        && (data.get('currentLocation', null) == null || data.currentLocation is string);
    }

    function isValidWarehouse(data) {
      return data.keys().hasAll(['name', 'address', 'inventoryLevel'])
        && data.name is string && data.name.size() <= 200
        && data.address is string && data.address.size() <= 500
        && data.inventoryLevel is string;
    }

    // --- Rules ---

    match /messages/{messageId} {
      // Secure list query: Authenticated users can see chat activity
      allow read: if isSignedIn();
      // Write: Mandate verification and schema
      allow create: if isVerified() && isValidMessage(request.resource.data);
      allow update, delete: if false; 
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidDriver(request.resource.data);
      // Limited update for status/location
      allow update: if isVerified() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'currentLocation']);
    }

    match /warehouses/{warehouseId} {
      allow read: if isSignedIn();
      allow create, update: if isVerified() && isValidWarehouse(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidOrder(request.resource.data);
      allow update: if isVerified() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'approvedBy']);
    }

    // Diagnostic connection point
    match /test/connection {
      allow read: if isSignedIn();
    }
  }
}
